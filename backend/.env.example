# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/autism_cdss

# JWT Configuration  
JWT_SECRET=your-secret-key-change-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION=1440

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ML Models
ML_MODEL_PATH=../ml/models/saved/
AUTISM_RISK_MODEL=autism_risk_classifier_v1.pkl
ESCALATION_MODEL=risk_escalation_predictor_v1.pkl

# Logging
LOG_LEVEL=INFO
